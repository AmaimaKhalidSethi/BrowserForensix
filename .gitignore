# =============================================================================
# BrowserForensix .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.eggs/
*.egg-info/
*.egg
dist/
build/

# -----------------------------------------------------------------------------
# Data files (extracted browser artifacts — sensitive, never commit)
# -----------------------------------------------------------------------------
data/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.env
.venv/
env/
venv/

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS-generated files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log

# -----------------------------------------------------------------------------
# LevelDB cache files
# -----------------------------------------------------------------------------
*.ldb
*.sst

# -----------------------------------------------------------------------------
# Testing artifacts
# -----------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
